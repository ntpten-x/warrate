      "regex": "^/api/manage\\-items(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/manage\\-items(?:/)?$"
    },
    {
      "page": "/api/overview",
      "regex": "^/api/overview(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/overview(?:/)?$"
    },
    {
      "page": "/api/pageviews",
      "regex": "^/api/pageviews(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/pageviews(?:/)?$"
    },
    {
      "page": "/api/prices",
      "regex": "^/api/prices(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/prices(?:/)?$"
    },
    {
      "page": "/api/trending",
      "regex": "^/api/trending(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/trending(?:/)?$"
    },
    {
      "page": "/api/trending/click",
      "regex": "^/api/trending/click(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/trending/click(?:/)?$"
    },
    {
      "page": "/api/units",
      "regex": "^/api/units(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/units(?:/)?$"
    },
    {
      "page": "/categories",
      "regex": "^/categories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/categories(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/items",
      "regex": "^/items(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/items(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
